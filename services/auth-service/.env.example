# Copier ce fichier en `.env` (make.bat init le fait automatiquement si `.env` est absent).
# Valeurs alignées avec docker-compose (service auth-db PostgreSQL).

APP_ENV=dev
APP_SECRET=change_me_in_production_please

DATABASE_URL="postgresql://auth_user:auth_pass@auth-db:5432/auth_db?serverVersion=16&charset=utf8"

JWT_PASSPHRASE=your_jwt_passphrase
