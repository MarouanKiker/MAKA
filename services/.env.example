# =============================================================================
# MAKA - Environment Variables for Docker Compose
# Copy this file to .env and adjust the values
# =============================================================================

# --- Application ---
APP_ENV=dev                          # dev or prod
APP_SECRET=change_me_in_production_please

# --- JWT Auth ---
JWT_PASSPHRASE=your_jwt_passphrase

# --- Gateway ---
PORT_NGINX=80

# --- Auth Database (PostgreSQL) ---
AUTH_DB_NAME=auth_db
AUTH_DB_USER=auth_user
AUTH_DB_PASSWORD=auth_pass

# --- CRM Database (PostgreSQL) ---
CRM_DB_NAME=crm_db
CRM_DB_USER=crm_user
CRM_DB_PASSWORD=crm_pass

# --- Observability ---
PORT_PROMETHEUS=9090
PORT_GRAFANA=3000
PORT_CADVISOR=8088
PORT_BLACKBOX=9115
PORT_DOCKER_STATS=9108
PORT_ELASTICSEARCH=9200
PORT_LOGSTASH_GELF=12201
PORT_LOGSTASH_HTTP=9600
PORT_KIBANA=5601
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# --- CRM Service (.NET) ---
ASPNETCORE_ENVIRONMENT=Development   # Development or Production

# --- Prospection /api/leads/scrape : DuckDuckGo (aucune clé API) ---

# --- Intelligence / Chatbot RAG++ (sales-service) ---
# Indispensable pour que le chatbot utilise Gemini (sinon mode réponses locales).
# Obtenir une clé : https://aistudio.google.com/apikey
# Sous Windows : enregistrer .env en UTF-8 et idéalement « fin de ligne LF » pour éviter un \r dans la clé.
# Pas de guillemets autour de la valeur. Puis : docker compose up -d --force-recreate sales-service
GEMINI_API_KEY=
# Optionnel : fallback si Gemini échoue (https://openrouter.ai/)
OPENROUTER_API_KEY=
