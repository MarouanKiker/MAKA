# ─── Application ───────────────────────────────────────────────────────────
APP_ENV=prod

# ─── JWT ────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=your_jwt_passphrase_here
JWT_SECRET=your_jwt_signing_secret_min_32_chars_here

# ─── RabbitMQ ───────────────────────────────────────────────────────────────
RABBITMQ_USER=maka
RABBITMQ_PASS=maka_secret

# ─── Auth Service (MySQL) ───────────────────────────────────────────────────
AUTH_DB_NAME=maka_auth
AUTH_DB_USER=auth_user
AUTH_DB_PASSWORD=auth_secret
AUTH_DB_ROOT_PASSWORD=root_secret

# ─── CRM Service (SQL Server) ──────────────────────────────────────────────
CRM_DB_NAME=maka_crm
CRM_DB_PASSWORD=CrmSecret123!

# ─── Stock Service (MySQL) ──────────────────────────────────────────────────
STOCK_DB_NAME=maka_stock
STOCK_DB_USER=stock_user
STOCK_DB_PASSWORD=stock_secret
STOCK_DB_ROOT_PASSWORD=root_secret

# ─── Sales Service (PostgreSQL) ─────────────────────────────────────────────
SALES_DB_NAME=maka_sales
SALES_DB_USER=sales_user
SALES_DB_PASSWORD=sales_secret

# ─── HR Service (PostgreSQL) ────────────────────────────────────────────────
HR_DB_NAME=maka_hr
HR_DB_USER=hr_user
HR_DB_PASSWORD=hr_secret

# ─── Finance Service (PostgreSQL) ───────────────────────────────────────────
FINANCE_DB_NAME=maka_finance
FINANCE_DB_USER=finance_user
FINANCE_DB_PASSWORD=finance_secret

# ─── Ports ───────────────────────────────────────────────────────────────────
PORT_NGINX=80
PORT_RABBITMQ=5672
PORT_RABBITMQ_MGMT=15672
PORT_AUTH_DB=3306
PORT_CRM_DB=1433
PORT_STOCK_DB=3307
PORT_SALES_DB=5432
PORT_HR_DB=5433
PORT_FINANCE_DB=5434
PORT_AUTH_SERVICE=8001
PORT_CRM_SERVICE=8002
PORT_STOCK_SERVICE=8003
PORT_SALES_SERVICE=8004
PORT_HR_SERVICE=8005
PORT_FINANCE_SERVICE=8006
PORT_FRONTEND=4200
